{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "bun-types"
    ],
    "baseUrl": ".",
    "paths": {
      "@copilotchat/shared/*": [
        "packages/shared/src/*"
      ],
      "@copilotchat/bridge/*": [
        "packages/bridge/src/*"
      ],
      "@copilotchat/web/*": [
        "apps/web/src/*"
      ]
    }
  }
}
