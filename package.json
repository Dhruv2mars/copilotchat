{
  "name": "copilotchat",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun run test:coverage",
    "test:coverage": "bun run --filter '*' test:coverage",
    "build": "bun run --filter '*' build",
    "check": "bun run --filter '*' check"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "@vitest/coverage-v8": "3.2.4",
    "bun-types": "1.3.5",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
